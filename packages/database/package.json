{
  "name": "@tavakoli/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "studio": "prisma studio",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.19.1",
    "@tavakoli/config": "workspace:*",
    "@tavakoli/core": "workspace:*"
  },
  "devDependencies": {
    "@node-rs/argon2": "1.8.3",
    "prisma": "5.19.1",
    "tsx": "4.19.0",
    "typescript": "5.5.3",
    "vitest": "2.0.5"
  }
}
