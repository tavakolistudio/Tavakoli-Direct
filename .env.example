# ─────────────────────────────────────────────────────────────────────────────
# Tavakoli Direct — environment variables
# Copy to `.env` and fill in. Mock mode requires NO Meta credentials.
# Never commit a real .env. See docs/SECURITY.md.
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ── Infrastructure ──────────────────────────────────────────────────────────
# Matches docker-compose.yml defaults.
DATABASE_URL=postgresql://tavakoli:tavakoli@localhost:5432/tavakoli_direct?schema=public
REDIS_URL=redis://localhost:6379

# ── Secrets ─────────────────────────────────────────────────────────────────
# AUTH_SECRET: >= 32 chars. Generate: `openssl rand -base64 48`
AUTH_SECRET=change-me-please-generate-a-long-random-string-min-32
# APP_ENCRYPTION_KEY: 32-byte key, base64-encoded. Generate: `openssl rand -base64 32`
APP_ENCRYPTION_KEY=change-me-32-byte-base64-key-AAAAAAAAAAAAAAAAAAA=

# ── URLs ────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3000
WORKER_URL=http://localhost:3001

# ── Instagram provider ──────────────────────────────────────────────────────
# `mock` (default, no credentials) or `meta` (requires the META_* values below).
INSTAGRAM_PROVIDER=mock

# ── Meta / Instagram Graph API (only required when INSTAGRAM_PROVIDER=meta) ───
# Verify the API version and permission names against current official Meta docs
# before enabling the meta provider. See docs/META_SETUP.md.
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_GRAPH_API_VERSION=v21.0
META_REDIRECT_URI=http://localhost:3000/api/integrations/meta/callback

# ── Storage ─────────────────────────────────────────────────────────────────
# `local` (default) writes to disk; `s3` uses the S3-compatible values below.
STORAGE_PROVIDER=local
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ── Observability (optional) ────────────────────────────────────────────────
SENTRY_DSN=

# ── Retention (optional; days) ──────────────────────────────────────────────
WEBHOOK_PAYLOAD_RETENTION_DAYS=30
